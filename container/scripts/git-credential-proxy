#!/bin/sh
# Git credential helper that fetches tokens from the NanoClaw credential proxy.
# Called by git when authentication is needed. Never stores real tokens.
#
# Usage: git config --global credential.helper /usr/local/bin/git-credential-proxy

# Only respond to "get" requests
if [ "$1" != "get" ]; then
  exit 0
fi

# Read the credential request from stdin (protocol, host, etc.)
host=""
protocol=""
while IFS='=' read -r key value; do
  case "$key" in
    host) host="$value" ;;
    protocol) protocol="$value" ;;
  esac
done

# Only provide credentials for github.com
case "$host" in
  github.com|*.github.com) ;;
  *) exit 0 ;;
esac

# Fetch token from credential proxy
INSTANCE_PARAM=""
if [ -n "$NANOCLAW_INSTANCE" ]; then
  INSTANCE_PARAM="?instance=$NANOCLAW_INSTANCE"
fi

TOKEN=$(curl -sf "${CREDENTIAL_PROXY}/_cred/github${INSTANCE_PARAM}" 2>/dev/null)
if [ -z "$TOKEN" ]; then
  exit 0
fi

echo "protocol=${protocol}"
echo "host=${host}"
echo "username=x-access-token"
echo "password=${TOKEN}"
